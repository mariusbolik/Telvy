---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content="Secure peer-to-peer audio and video calls. No signup, no data stored. Hosted in Switzerland." />
  </head>
  <body class="bg-white text-gray-900 min-h-screen antialiased font-sans">
    <slot />
  </body>
</html>
